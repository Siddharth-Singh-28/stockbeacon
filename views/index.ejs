<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>StockBeacon</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/styles/main.css">
</head>

<body>

<%- include("partials/header") %>

<main>

<!-- HERO -->
<section class="hero-section text-center">

  <h1 class="hero-title">StockBeacon</h1>

  <p class="hero-subtitle">
    Track stock prices instantly
  </p>

  <form action="/stock" method="POST" class="hero-search">

    <div class="input-group input-group-lg">

      <input
        type="text"
        name="symbol"
        class="form-control hero-input"
        placeholder="Enter stock symbol (AAPL, TSLA...)"
        required>

      <button class="btn hero-btn">
        Search
      </button>

    </div>

  </form>

</section>



<!-- TRENDING STOCKS -->
<section class="container trending-section">

  <h3 class="section-title">Trending Stocks</h3>

  <div class="row g-4 mt-2">

    <% if (stocks && stocks.length > 0) { %>

      <% stocks.forEach(stock => { %>

        <div class="col-md-3">

          <div class="stock-card p-3">

            <h5><%= stock["01. symbol"] %></h5>

            <p class="stock-name">
              $<%= Number(stock["05. price"]).toFixed(2) %>
            </p>

            <span class="<%= stock['10. change percent'].includes('-') ? 'text-danger' : 'text-success' %>">
              <%= stock["10. change percent"] %>
            </span>

          </div>

        </div>

      <% }) %>

    <% } else { %>

      <p class="text-muted">Stock data unavailable.</p>

    <% } %>

  </div>

</section>

</main>

<%- include("partials/footer") %>

</body>
</html>