<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<title>StockBeacon</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/styles/main.css">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

<%- include("partials/header") %>

<main class="container stock-page">

<% if(error){ %>

<div class="alert alert-danger text-center mt-5">
<%= error %>
</div>

<% } %>

<% if(quote){ %>

<!-- STOCK HERO -->
<div class="stock-hero">

<h1><%= quote["01. symbol"] %></h1>

<h2 class="price">
$<%= Number(quote["05. price"]).toFixed(2) %>
</h2>

<p class="<%= quote['10. change percent'].includes('-') ? 'text-danger' : 'text-success' %>">

<%= quote["09. change"] %>
(<%= quote["10. change percent"] %>)

</p>

</div>


<!-- CHART -->
<div class="chart-container">

<canvas id="stockChart"></canvas>

</div>


<!-- STATS -->
<div class="row stock-stats">

<div class="col-md-3 stat-card">
<p>Open</p>
<h5>$<%= quote["02. open"] %></h5>
</div>

<div class="col-md-3 stat-card">
<p>High</p>
<h5>$<%= quote["03. high"] %></h5>
</div>

<div class="col-md-3 stat-card">
<p>Low</p>
<h5>$<%= quote["04. low"] %></h5>
</div>

<div class="col-md-3 stat-card">
<p>Volume</p>
<h5><%= quote["06. volume"] %></h5>
</div>

</div>

<% } %>

</main>

<%- include("partials/footer") %>

<script>

<% if(history){ %>

const dates = <%- JSON.stringify(Object.keys(history).slice(0,30).reverse()) %>;

const prices = <%- JSON.stringify(
Object.values(history)
.slice(0,30)
.reverse()
.map(d => parseFloat(d["4. close"]))
) %>;

const ctx = document.getElementById("stockChart");

new Chart(ctx, {

type:"line",

data:{
labels:dates,

datasets:[{
data:prices,
borderColor:"#4ade80",
backgroundColor:"rgba(74,222,128,0.1)",
tension:0.3
}]

},

options:{
plugins:{legend:{display:false}},
scales:{
  x:{
    ticks:{
      color:"#aaa",
      maxTicksLimit:6
    },
    grid:{
      display:false
    }
  },
  y:{
    ticks:{
      color:"#aaa"
    }
  }
}

}

});

<% } %>

</script>

</body>
</html>